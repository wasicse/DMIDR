# Copy this file to configs/local.env and update the values.
# Then run:
#   bash scripts/run_pipeline.sh configs/local.env

SEQ_NAME=example_seq
INPUT_FASTA=/absolute/path/to/example_seq.fasta
BLAST_DB=/absolute/path/to/blast/database/nr
DISPREDICT_IMAGE=wasicse/dispredict3.0:latest
MAX_MUTATIONS=5

# Optional overrides
CONTAINER_PREFIX=example_seq
PSSM_OUT=
DISPRED_DIR=
FASTA_OUT=
RESULTS_DIR=
ORIGINAL_DISPRED=

# Optional step control: set to 1 to skip a stage
SKIP_PSSM=0
SKIP_ORIGINAL_DISPREDICT=0
SKIP_MUTANT_GENERATION=0
SKIP_MUTANT_DISPREDICT=0
