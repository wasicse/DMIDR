; --- Minimal energy minimization .mdp (GROMACS) ---
integrator  = steep      ; or cg
emtol       = 1000.0
emstep      = 0.001
nsteps      = 100000

; Neighborsearching
nstlist     = 10
cutoff-scheme = Verlet
ns_type     = grid
rlist       = 1.0
rcoulomb    = 1.0
rvdw        = 1.0

; Electrostatics
coulombtype = PME
pme_order   = 4
fourierspacing = 0.12

constraints = none
