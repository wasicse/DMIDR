# Copy this file to configs/local.env and fill in the required values.
# Then run:
#   bash run_all.sh [configs/local.env]

# ── Required ───────────────────────────────────────────────────────────────────

BLAST_DB=/absolute/path/to/blast/database/nr
ESMDISPRED_IMAGE=wasicse/esmdispred:latest
LARGE_MODELS_DIR=/absolute/path/to/DMIDR/scripts/tools/ESMDisPred/largeModels

# ── Optional overrides (defaults shown) ───────────────────────────────────────

INPUT_FASTA=/absolute/path/to/DMIDR/data/input/example.fasta

# Mutation strategy: random (default) or consecutive
MUTATION_MODE=random

# Shared filter
MIN_DISORDER_PROB=0.5

# Random mode — scatter N independent variants across disordered sites
NUM_VARIANTS=200        # number of mutant sequences to generate
MUTATIONS_PER_SEQ=5     # mutations per variant
MIN_SPACING=5           # minimum residue gap between mutation sites
# MUTATION_SEED=42      # uncomment for reproducible results

# Consecutive mode — sliding window blocks (used when MUTATION_MODE=consecutive)
MAX_MUTATIONS=5         # maximum block size (1..MAX_MUTATIONS windows tested)
REQUIRED_RATIO=0.8      # fraction of block residues that must be eligible

# ESMDisPred model: 1=ESMDisPred-1  2=ESMDisPred-2  3=ESMDisPred-2PDB  4=ESMDisPred-DNN
MODEL=3

# ── Remote MSA generation via SLURM (scripts/generate_msa_remote.sh) ─────────
# Use when this server can't reach the ColabFold MSA server directly.
# The remote must have SSH access and SLURM.  colabfold is auto-installed
# into ~/colabfold_venv on the remote on first run.
#
# MSA_REMOTE_HOST=mkabir3@jupyterhub.cs.dmz    # required
# MSA_REMOTE_DIR=~/colabfold_scratch           # required — writable scratch dir
#
# SLURM resource overrides (optional — defaults shown):
# MSA_SLURM_PARTITION=                         # leave blank for cluster default
# MSA_SLURM_TIME=02:00:00
# MSA_SLURM_MEM=8G
# MSA_SLURM_CPUS=4
